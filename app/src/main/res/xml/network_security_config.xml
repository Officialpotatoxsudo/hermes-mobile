<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Hermes Mobile requires HTTPS for remote connections.
        Local emulator/dev HTTP is allowed for localhost and 10.0.2.2 only;
        connection setup rejects remote http:// URLs before save.

        For self-signed / private CA setups, place the CA cert PEM as
        app/src/main/res/raw/hermes_ca.pem and uncomment the domain-config block.
        For Let's Encrypt / public CA reverse proxy, no extra config needed.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">::1</domain>
    </domain-config>
    <!--
    <domain-config>
        <domain includeSubdomains="true">your-hermes-server.example.com</domain>
        <trust-anchors>
            <certificates src="@raw/hermes_ca"/>
        </trust-anchors>
    </domain-config>
    -->
</network-security-config>
