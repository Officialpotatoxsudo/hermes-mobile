<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
        Local chat history, copied media, and credentials are scoped to the
        current device and connection. Restoring these without matching keys or
        account context can expose stale/private data or break startup.
    -->
    <exclude domain="database" path="hermes.db" />
    <exclude domain="database" path="hermes.db-shm" />
    <exclude domain="database" path="hermes.db-wal" />
    <exclude domain="file" path="datastore/hermes_app_prefs.preferences_pb" />
    <exclude domain="file" path="datastore/hermes_secure_prefs.preferences_pb" />
    <exclude domain="file" path="hermes-media/" />
</full-backup-content>
